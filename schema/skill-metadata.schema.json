{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/skill-metadata.schema.json",
  "title": "Skill Metadata",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "version",
    "description",
    "entry",
    "compatibleTargets",
    "minAgentVersion",
    "testedAgentVersions"
  ],
  "properties": {
    "schemaVersion": {"type": "string", "minLength": 1},
    "name": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "authors": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "tags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "entry": {"type": "string", "minLength": 1},
    "references": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "compatibleTargets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude", "cursor", "opencode", "codex", "generic"]
      },
      "minItems": 1
    },
    "minAgentVersion": {"type": "string", "minLength": 1},
    "testedAgentVersions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    }
  },
  "additionalProperties": false
}
