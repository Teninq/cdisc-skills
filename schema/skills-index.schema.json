{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/skills-index.schema.json",
  "title": "Skills Index",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "skills"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "entry", "metadata"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "entry": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
